# ── Bot credentials ──────────────────────────────────────────────────────────
BOT_TOKEN=your_bot_token_here
BOT_USERNAME=your_bot_username          # without @

# ── Owner settings ────────────────────────────────────────────────────────────
OWNER_ID=123456789                      # Your Telegram numeric user ID

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///data/tgbot.db
# For PostgreSQL: postgresql+asyncpg://user:password@host/dbname

# ── Default timings (seconds) ─────────────────────────────────────────────────
AUTO_DELETE_CMD_DELAY=3                 # Delete command/bot/join/left messages
AUTO_DELETE_EDITED_DELAY=25            # Delete edited messages after N seconds

# ── Anti-spam defaults ────────────────────────────────────────────────────────
FLOOD_RATE=5                            # Max messages per window
FLOOD_WINDOW=5                          # Seconds window for flood detection
SPAM_MUTE_DURATION=600                 # Auto-mute duration on spam (seconds)

# ── Webhook (leave empty to use polling) ─────────────────────────────────────
WEBHOOK_URL=
WEBHOOK_PORT=8443

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_CHANNEL_ID=                         # Optional: channel/group for action logs
